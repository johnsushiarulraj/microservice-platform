{
  "info": {
    "name": "Microservice Template",
    "description": "Postman collection for the Spring Boot Microservice Template. Includes auth flow via Keycloak and all API endpoints.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "_postman_id": "microservice-template-v1"
  },
  "variable": [
    {"key": "base_url", "value": "http://localhost:18080/template", "type": "string"},
    {"key": "keycloak_url", "value": "http://localhost:18081", "type": "string"},
    {"key": "realm", "value": "template", "type": "string"},
    {"key": "client_id", "value": "microservice-template", "type": "string"},
    {"key": "client_secret", "value": "template-secret", "type": "string"},
    {"key": "access_token", "value": "", "type": "string"}
  ],
  "auth": {
    "type": "bearer",
    "bearer": [{"key": "token", "value": "{{access_token}}", "type": "string"}]
  },
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Get Token (testuser)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var json = pm.response.json();",
                  "pm.collectionVariables.set('access_token', json.access_token);",
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Has access_token', () => pm.expect(json.access_token).to.be.a('string'));"
                ]
              }
            }
          ],
          "request": {
            "auth": {"type": "noauth"},
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/x-www-form-urlencoded"}],
            "body": {
              "mode": "urlencoded",
              "urlencoded": [
                {"key": "grant_type", "value": "password"},
                {"key": "client_id", "value": "{{client_id}}"},
                {"key": "client_secret", "value": "{{client_secret}}"},
                {"key": "username", "value": "testuser"},
                {"key": "password", "value": "password"}
              ]
            },
            "url": "{{keycloak_url}}/realms/{{realm}}/protocol/openid-connect/token"
          }
        },
        {
          "name": "Get Token (adminuser)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var json = pm.response.json();",
                  "pm.collectionVariables.set('access_token', json.access_token);",
                  "pm.test('Status 200', () => pm.response.to.have.status(200));"
                ]
              }
            }
          ],
          "request": {
            "auth": {"type": "noauth"},
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/x-www-form-urlencoded"}],
            "body": {
              "mode": "urlencoded",
              "urlencoded": [
                {"key": "grant_type", "value": "password"},
                {"key": "client_id", "value": "{{client_id}}"},
                {"key": "client_secret", "value": "{{client_secret}}"},
                {"key": "username", "value": "adminuser"},
                {"key": "password", "value": "password"}
              ]
            },
            "url": "{{keycloak_url}}/realms/{{realm}}/protocol/openid-connect/token"
          }
        }
      ]
    },
    {
      "name": "Template Items",
      "item": [
        {
          "name": "Create Template Item",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 201', () => pm.response.to.have.status(201));",
                  "var json = pm.response.json();",
                  "pm.collectionVariables.set('item_id', json.id);",
                  "pm.test('Name matches', () => pm.expect(json.name).to.eql('Test Item'));",
                  "pm.test('Status is ACTIVE', () => pm.expect(json.status).to.eql('ACTIVE'));"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Test Item\",\n  \"amount\": 99.99,\n  \"currency\": \"USD\",\n  \"description\": \"A test template item\"\n}"
            },
            "url": "{{base_url}}/api/v1/templates"
          }
        },
        {
          "name": "Get All Template Items",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Has pageable', () => pm.expect(pm.response.json().pageable).to.exist);"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/api/v1/templates?page=0&size=10",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "templates"],
              "query": [
                {"key": "page", "value": "0"},
                {"key": "size", "value": "10"}
              ]
            }
          }
        },
        {
          "name": "Get Template Item by ID",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('ID matches', () => pm.expect(pm.response.json().id).to.eql(pm.collectionVariables.get('item_id')));"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/v1/templates/{{item_id}}"
          }
        },
        {
          "name": "Delete Template Item (Admin)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 204', () => pm.response.to.have.status(204));"
                ]
              }
            }
          ],
          "request": {
            "method": "DELETE",
            "url": "{{base_url}}/api/v1/templates/{{item_id}}"
          }
        }
      ]
    },
    {
      "name": "Saga",
      "item": [
        {
          "name": "Start Saga",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 201', () => pm.response.to.have.status(201));",
                  "var json = pm.response.json();",
                  "pm.collectionVariables.set('saga_id', json.id);",
                  "pm.test('State is INITIATED', () => pm.expect(json.state).to.eql('INITIATED'));"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"correlationId\": \"test-correlation-123\",\n  \"payload\": \"{}\"\n}"
            },
            "url": "{{base_url}}/api/v1/saga"
          }
        },
        {
          "name": "Get Saga by ID",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('ID matches', () => pm.expect(pm.response.json().id).to.eql(pm.collectionVariables.get('saga_id')));"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/v1/saga/{{saga_id}}"
          }
        }
      ]
    },
    {
      "name": "Observability",
      "item": [
        {
          "name": "Health",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Status UP', () => pm.expect(pm.response.json().status).to.eql('UP'));"
                ]
              }
            }
          ],
          "request": {
            "auth": {"type": "noauth"},
            "method": "GET",
            "url": "{{base_url}}/actuator/health"
          }
        },
        {
          "name": "Prometheus Metrics",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Contains JVM metrics', () => pm.expect(pm.response.text()).to.include('jvm_memory'));"
                ]
              }
            }
          ],
          "request": {
            "auth": {"type": "noauth"},
            "method": "GET",
            "url": "{{base_url}}/actuator/prometheus"
          }
        },
        {
          "name": "OpenAPI Docs",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Has openapi field', () => pm.expect(pm.response.json().openapi).to.be.a('string'));"
                ]
              }
            }
          ],
          "request": {
            "auth": {"type": "noauth"},
            "method": "GET",
            "url": "{{base_url}}/v3/api-docs"
          }
        }
      ]
    },
    {
      "name": "Security",
      "item": [
        {
          "name": "Unauthenticated returns 401",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 401', () => pm.response.to.have.status(401));"
                ]
              }
            }
          ],
          "request": {
            "auth": {"type": "noauth"},
            "method": "GET",
            "url": "{{base_url}}/api/v1/templates"
          }
        }
      ]
    }
  ]
}
