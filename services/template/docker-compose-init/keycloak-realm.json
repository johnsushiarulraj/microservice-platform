{
  "realm": "template",
  "enabled": true,
  "sslRequired": "none",
  "registrationAllowed": false,
  "roles": {
    "realm": [
      { "name": "TEMPLATE_USER", "composite": false },
      { "name": "TEMPLATE_ADMIN", "composite": false }
    ]
  },
  "clients": [
    {
      "clientId": "microservice-template",
      "enabled": true,
      "publicClient": false,
      "secret": "template-secret",
      "directAccessGrantsEnabled": true,
      "standardFlowEnabled": true,
      "redirectUris": ["*"],
      "webOrigins": ["*"],
      "protocol": "openid-connect"
    }
  ],
  "users": [
    {
      "username": "admin",
      "enabled": true,
      "firstName": "Admin",
      "lastName": "User",
      "email": "admin@example.com",
      "emailVerified": true,
      "credentials": [
        {
          "type": "password",
          "value": "admin",
          "temporary": false
        }
      ],
      "realmRoles": ["TEMPLATE_USER", "TEMPLATE_ADMIN"]
    },
    {
      "username": "testuser",
      "enabled": true,
      "firstName": "Test",
      "lastName": "User",
      "email": "testuser@example.com",
      "emailVerified": true,
      "credentials": [
        {
          "type": "password",
          "value": "password",
          "temporary": false
        }
      ],
      "realmRoles": ["TEMPLATE_USER"]
    }
  ]
}
